# PRISM Environment Variables — copy to .env and fill in real values
# Never commit .env to git

# Slack (Brian Corp - PRISM Signals app)
PRISM_SLACK_TOKEN=xoxb-REPLACE-WITH-REAL-TOKEN
PRISM_SLACK_CHANNEL=C0AU1AYT2DQ

# Tiingo (price data + news sentiment)
TIINGO_API_KEY=REPLACE-WITH-REAL-KEY

# FRED (macro features)
FRED_API_KEY=REPLACE-WITH-REAL-KEY

# Exness MT5 (live trading)
MT5_LOGIN=REPLACE-WITH-ACCOUNT-NUMBER
MT5_SERVER=Exness-MT5Real
MT5_PASSWORD=REPLACE-WITH-PASSWORD
MT5_PATH=

# PRISM config
PRISM_INSTRUMENTS=XAUUSD,EURUSD,GBPUSD
PRISM_EXECUTION_MODE=CONFIRM
PRISM_SCAN_INTERVAL=60
PRISM_CONFIRM_TIMEOUT_SEC=300
PRISM_APPROVERS=REPLACE-WITH-SLACK-USER-ID

# Runtime state directory (persists last_brief_date so a restart mid-day
# doesn't re-fire the 22:00 UTC summary). Relative paths resolve from the
# runner's working directory. This dir is gitignored.
PRISM_STATE_DIR=state

# Risk / position sizing
PRISM_RISK_PCT=0.01        # 1% of balance per trade
PRISM_MAX_CONCURRENT=3     # max open PRISM positions at once

# Allow lot sizing to fall back to the retail pip-value approximation when
# MT5 symbol_info is unavailable on a connected bridge. OFF by default — a
# live bridge without symbol_info is treated as a broken broker-symbol map
# and trades are rejected (lot=0) rather than risk a mis-sized position.
# Only set to 1 for demo/dev runs where you accept the ~10-20% drift on
# XAUUSD and JPY-quoted pairs.
# PRISM_ALLOW_APPROX_PIP_VALUE=0

# Bars of history fetched per timeframe per scan. 500 covers the 200-period
# EMA + ATR lookbacks used throughout the signal stack. Reduce for replay
# or back-test runs that only need recent bars.
# PRISM_BAR_COUNT=500

# Daily drawdown kill-switch — halts new entries for the rest of the UTC
# trading day once realized loss crosses either threshold (OR, not AND).
# Existing positions are NOT closed — the guard only prevents new ones.
# Resets automatically at next UTC midnight.
PRISM_MAX_DAILY_LOSS_PCT=0.03    # 3% of start-of-day balance (≈ 3R at 1% risk)
# PRISM_MAX_DAILY_LOSS_USD=300   # optional absolute cap in USD; leave blank to disable

# MT5 reconnect tuning — the bridge heartbeats MT5 on every scan and
# reinit's the terminal on failure with exponential backoff. Defaults
# are safe for Exness-MT5Real; adjust only if you see repeated alerts.
# PRISM_MT5_RECONNECT_BASE_SEC=10       # first backoff (doubles on each failure)
# PRISM_MT5_RECONNECT_MAX_SEC=300       # cap at 5min so bad creds don't hammer
# PRISM_MT5_DISCONNECT_ALERT_SEC=120    # post Slack alert after 2min disconnected
